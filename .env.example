# =========================
# App
# =========================
APP_NAME=TaskFlow API
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1
HOST=0.0.0.0
PORT=8000

# =========================
# Database (PostgreSQL)
# =========================
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=taskflow
POSTGRES_USER=taskflow_user
POSTGRES_PASSWORD=taskflow_password
DATABASE_URL=postgresql+psycopg://taskflow_user:taskflow_password@postgres:5432/taskflow

# =========================
# JWT
# =========================
JWT_SECRET_KEY=change_me_super_secret_key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# =========================
# Redis / Celery
# =========================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=redis://redis:6379/0

CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# =========================
# CORS
# =========================
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# =========================
# Logging
# =========================
LOG_LEVEL=INFO

# =========================
# Email (stub for now)
# =========================
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=example_user
SMTP_PASSWORD=example_password
SMTP_FROM=noreply@example.com
